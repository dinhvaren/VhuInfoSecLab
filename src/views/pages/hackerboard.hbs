<div class="glitch">
  <div class="glitch__img glitch__img_leaderboard"></div>
  <div class="glitch__img glitch__img_leaderboard"></div>
  <div class="glitch__img glitch__img_leaderboard"></div>
  <div class="glitch__img glitch__img_leaderboard"></div>
  <div class="glitch__img glitch__img_leaderboard"></div>
</div>

<div class="navbar-dark text-white">
  <div class="container">
    {{#if user}}
      {{#if (isRole user.role "admin")}}
        {{> navbar-admin}}
      {{else}}
        {{> navbar-auth}}
      {{/if}}
    {{else}}
      {{> navbar}}
    {{/if}}
  </div>
</div>

<div class="jumbotron bg-transparent mb-0 pt-3 radius-0">
  <div class="container">
    <div class="row">
      <div class="col-xl-12">
        <h1 class="display-1 bold color_white content__title text-center">
          <span class="color_danger">HACKER</span>BOARD
        </h1>

        <p class="text-grey lead text-spacey text-center hackerFont">
          {{message}}
        </p>

        <div class="row justify-content-center my-5">
          <div class="col-xl-10">
            <canvas id="myChart" style="min-height: 350px;"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="row mt-5 justify-content-center">
      <div class="col-xl-10">
        <div class="table-responsive neon-table-container">
          <table class="table table-borderless neon-table text-center">
            <thead>
              <tr>
                <th>#</th>
                <th>Team Name</th>
                <th>Members</th>
                <th>Challenges Solved</th>
                <th>Score</th>
                <th>Last Submission</th>
              </tr>
            </thead>

            <tbody>
              {{#each teams}}
              <tr>
                <td>{{rank}}</td>
               <td>
                <span class="team-name bold"
                  style="
                    color: {{color}};
                  ">
                  {{#if (eq rank 1)}}🥇{{/if}}
                  {{#if (eq rank 2)}}🥈{{/if}}
                  {{#if (eq rank 3)}}🥉{{/if}}  
                  {{name}}
                </span>
              </td>
                <td><span class="team-name bold" style="color: {{color}}; text-shadow: 0 0 10px {{color}};">{{memberCount}}</span></td>
                <td><span class="team-name bold" style="color: {{color}}; text-shadow: 0 0 10px {{color}};">{{solvedCount}}</span></td>
                <td>
                  <span class="score bold" style="color: {{color}}; text-shadow: 0 0 10px {{color}};">
                    {{score}}
                  </span>
                </td>
                <td>
                  {{#if lastSubmission}}
                    {{formatDate lastSubmission}}
                  {{else}}
                    —
                  {{/if}}
                </td>
              </tr>
              {{else}}
              <tr>
                <td colspan="6" class="text-center text-muted hackerFont">
                  No teams found.
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>

<script>
  const chartData = JSON.parse('{{{chartData}}}' || '[]');
  const ctx = document.getElementById("myChart").getContext("2d");

  const allPoints = chartData.flatMap(team => team.data || []);

  const maxSolved = Math.max(1, ...allPoints.map(p => Number(p.x || 0)));
  const maxScore = Math.max(0, ...allPoints.map(p => Number(p.y || 0)));

  const niceMaxSolved = maxSolved + 1;
  const niceMaxScore = maxScore <= 0
    ? 100
    : Math.ceil((maxScore + 100) / 100) * 100;

  const stepSize = niceMaxScore <= 500
    ? 100
    : Math.ceil(niceMaxScore / 7 / 100) * 100;

  const datasets = chartData.map((team, index) => {
    const color = team.color || `hsl(${(index * 137.508) % 360}, 100%, 55%)`;

    const data = (team.data || [])
      .map(p => ({
        x: Number(p.x || 0),
        y: Number(p.y || 0),
      }))
      .filter(p => Number.isFinite(p.x) && Number.isFinite(p.y))
      .sort((a, b) => a.x - b.x);

    return {
      label: team.label,
      data,
      borderColor: color,
      backgroundColor: color,
      pointStyle: "circle",
      pointRadius: 5,
      pointHoverRadius: 8,
      pointBackgroundColor: color,
      pointBorderColor: color,
      borderWidth: 3,
      tension: 0.4,
      fill: false,
      showLine: true,
    };
  });

  new Chart(ctx, {
    type: "line",
    data: { datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      parsing: false,
      plugins: {
        legend: {
          labels: {
            color: "#00ffff",
            usePointStyle: true,
            pointStyle: "circle",
            boxWidth: 10,
            boxHeight: 10,
            font: {
              family: "Hack",
              size: 14,
            },
          },
        },
        tooltip: {
          backgroundColor: "rgba(0,255,255,0.15)",
          borderColor: "#00ffff",
          borderWidth: 1,
          titleColor: "#fff",
          bodyColor: "#fff",
          displayColors: true,
          callbacks: {
            title: (items) => `${items[0].parsed.x} challenge solved`,
            label: (ctx) => `${ctx.dataset.label}: ${ctx.parsed.y} pts`,
          },
        },
      },
      scales: {
        x: {
          type: "linear",
          min: 0,
          max: niceMaxSolved,
          title: {
            display: true,
            text: "Challenges Solved",
            color: "#00ffff",
            font: { family: "Hack", size: 14 },
          },
          ticks: {
            color: "#aaa",
            stepSize: 1,
            font: { family: "Hack" },
          },
          grid: {
            color: "rgba(0,255,255,0.1)",
          },
        },
        y: {
          beginAtZero: true,
          min: 0,
          suggestedMax: niceMaxScore,
          title: {
            display: true,
            text: "Score",
            color: "#00ffff",
            font: { family: "Hack", size: 14 },
          },
          ticks: {
            color: "#aaa",
            stepSize,
            font: { family: "Hack" },
          },
          grid: {
            color: "rgba(0,255,255,0.1)",
          },
        },
      },
      elements: {
        line: { fill: false },
      },
    },
  });
</script>