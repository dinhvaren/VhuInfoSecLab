<!-- Register Form -->
<div class="jumbotron bg-transparent mb-0 pt-3 radius-0">
  <div class="container">
    <div class="row">
      <div class="col-xl-10">
        <h1 class="display-1 bold color_white content__title">JOIN THE NETWORK</h1>
        <p class="text-grey text-spacey hackerFont lead mb-5">
          Register as an individual participant and become part of the VHU CTF
          community.
        </p>

        <div class="row hackerFont">
          <div class="col-md-6">
            {{#if message}}
              <div id="register-message" class="login-error hackerFont">
                {{message}}
              </div>
            {{/if}}
            <form action="/auth/register-individual" method="POST">
              <div class="form-group">
                <input
                  type="text"
                  class="form-control"
                  name="username"
                  placeholder="Full Name"
                  required
                />
              </div>

              <div class="form-group">
                <input
                  type="email"
                  class="form-control"
                  name="email"
                  placeholder="Email (e.g., you@vhu.edu.vn)"
                  required
                />
              </div>

              <div class="form-group">
                <input
                  type="password"
                  class="form-control"
                  name="password"
                  placeholder="Password"
                  required
                />
              </div>

              <div class="form-group">
                <input
                  type="password"
                  class="form-control"
                  name="confirm_password"
                  placeholder="Confirm Password"
                  required
                />
                <small id="passHelp" class="form-text text-muted">
                  Make sure passwords match and keep it secret.
                </small>
              </div>

              <div class="custom-control custom-checkbox my-4">
                <input
                  type="checkbox"
                  class="custom-control-input"
                  id="agree"
                  required
                />
                <label class="custom-control-label" for="agree">
                  I agree to follow the VHU CTF Rules and Code of Conduct.
                </label>
              </div>

              <button
                type="submit"
                class="btn btn-outline-danger btn-shadow px-3 my-2 ml-0 ml-sm-1 text-left"
              >
                <h4>Register</h4>
              </button>

              <small id="registerHelp" class="mt-2 form-text text-muted">
                Already registered?
                <a href="/auth/login">Login here</a>
              </small>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<script
