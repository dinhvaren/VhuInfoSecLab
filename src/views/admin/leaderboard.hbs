<div class="glitch">
  <div class="glitch__img"></div>
  <div class="glitch__img"></div>
  <div class="glitch__img"></div>
  <div class="glitch__img"></div>
</div>

<div class="navbar-dark text-white">
  <div class="container">
    {{> navbar-admin}}
  </div>
</div>

<div class="jumbotron bg-transparent mb-0 pt-3 pb-0 radius-0">
  <div class="container">
    <div class="row">

      <!-- Sidebar -->
      <div class="col-md-3">
        <h4 class="bold color_white mb-4">Admin Panel</h4>

        <div class="list-group">
          <a href="/admin" class="list-group-item list-group-item-action">Dashboard</a>
          <a href="/admin/leaderboard" class="list-group-item list-group-item-action active">Leaderboard</a>
          <a href="/admin/users" class="list-group-item list-group-item-action">Users</a>
          <a href="/admin/teams" class="list-group-item list-group-item-action">Teams</a>
          <a href="/admin/challenges" class="list-group-item list-group-item-action">Challenges</a>
          <a href="/admin/submissions" class="list-group-item list-group-item-action">Submissions</a>
        </div>
      </div>

      <!-- Main -->
      <div class="col-md-9">
        <h2 class="bold color_white mb-4">Leaderboard</h2>
        <p class="text-grey lead hackerFont">
          Live ranking of all participating teams.
        </p>

        <!-- Chart -->
        <div class="card bg-transparent border border-light mb-4">
          <div class="card-body">
            <h5 class="color_white mb-3">📈 Score Progression</h5>

            <div style="position: relative; height: 360px; width: 100%;">
              <canvas id="leaderChart"></canvas>
            </div>
          </div>
        </div>

        <!-- Table -->
        <table class="table table-hover table-striped text-light">
          <thead class="thead-dark">
            <tr>
              <th>#</th>
              <th>Team Name</th>
              <th>Members</th>
              <th>Challenges Solved</th>
              <th>Total Flags</th>
              <th>Score</th>
              <th>Last Submission</th>
            </tr>
          </thead>

          <tbody class="hackerFont">
            {{#each teams}}
            <tr>
              <td>{{rank}}</td>
              <td>{{name}}</td>
              <td>{{memberCount}}</td>
              <td>{{solvedCount}}</td>
              <td>{{totalFlags}}</td>
              <td>
                <span class="color_danger bold">{{score}}</span>
              </td>
              <td>
                {{#if lastSubmission}}
                  {{formatDate lastSubmission}}
                {{else}}
                  —
                {{/if}}
              </td>
            </tr>
            {{else}}
            <tr>
              <td colspan="7" class="text-center text-muted">
                No teams found.
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>

      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.3.1.slim.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<script>
  const chartData = {{{chartData}}};
  const ctx = document.getElementById("leaderChart").getContext("2d");

  new Chart(ctx, {
    type: "line",
    data: {
      datasets: chartData.map((team) => ({
        label: team.label,
        data: team.data,
        borderColor: team.color,
        backgroundColor: team.color,
        borderWidth: 2,
        tension: 0.25,
        fill: false,
        pointRadius: 4,
        pointHoverRadius: 6,
      })),
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      parsing: false,

      plugins: {
        legend: {
          labels: {
            color: "#fff",
          },
        },
        tooltip: {
          callbacks: {
            title: function (items) {
              return "Solved: " + items[0].parsed.x;
            },
            label: function (item) {
              return item.dataset.label + ": " + item.parsed.y + " pts";
            },
          },
        },
      },

      scales: {
        x: {
          type: "linear",
          beginAtZero: true,
          title: {
            display: true,
            text: "Challenges Solved",
            color: "#fff",
          },
          ticks: {
            color: "#aaa",
            stepSize: 1,
            precision: 0,
          },
          grid: {
            color: "rgba(0,255,255,0.1)",
          },
        },
        y: {
          beginAtZero: true,
          title: {
            display: true,
            text: "Score",
            color: "#fff",
          },
          ticks: {
            color: "#aaa",
          },
          grid: {
            color: "rgba(0,255,255,0.1)",
          },
        },
      },
    },
  });
</script>